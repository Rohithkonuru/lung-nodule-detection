run = "if [ ! -f project/models/finetuned/retinanet_lung_best.pth ]; then echo 'Downloading weights...' && mkdir -p project/models/finetuned && curl -L -o project/models/finetuned/retinanet_lung_best.pth https://github.com/Rohithkonuru/lung-nodule-detection/releases/download/v1.0.0/retinanet_lung_best.pth; fi && pip install torch torchvision --index-url https://download.pytorch.org/whl/cpu && pip install -r project/backend/requirements.txt && pip install -r project/backend/requirements-ml.txt && cd project/frontend && npm install && npm run build && cd ../backend && python run_server.py"
entrypoint = "project/backend/run_server.py"
