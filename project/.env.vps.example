# Copy this file to .env.vps before deployment.
# Linux command: cp .env.vps.example .env.vps

POSTGRES_DB=lungdb
POSTGRES_USER=lung
POSTGRES_PASSWORD=replace_with_long_random_password

SECRET_KEY=replace_with_long_random_secret_key_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated browser origins allowed to call backend APIs.
# Include your final domain and optionally your server IP during setup.
CORS_ORIGINS=https://your-domain.com,http://your-vps-ip

# File must exist inside ./models
MODEL_WEIGHTS_FILE=retinanet_best.pth

# Optional runtime toggles
ENABLE_DOMAIN_GUARD=True
DEBUG_PRINT_RAW_OUTPUTS=False
PRINT_DEBUG_COUNTS=False
