APP_NAME=Lung Nodule Detection API
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

SECRET_KEY=your-super-secret-key-for-production-change-this-urgently-12345
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# For local pilot deployment, prefer PostgreSQL over SQLite.
DATABASE_URL=sqlite:///backend_dev.db

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=uploads/scans
MODEL_WEIGHTS_PATH=../models/retinanet_best.pth
CONFIDENCE_THRESHOLD=0.015
MIN_NODULE_SIZE_MM=2.0
NMS_IOU_THRESHOLD=0.2
DETECTION_STRIDE=32
MAX_UPLOAD_SIZE_MB=500
ALLOWED_UPLOAD_EXTENSIONS=.nii,.nii.gz,.mhd,.jpg,.jpeg,.png,.dcm

# Temporary debug mode (Stage 1-2): raw outputs with filters disabled.
DISABLE_FILTERS_FOR_TESTING=False
USE_LUNG_MASK=True
USE_SIZE_FILTER=True
USE_ROI_FILTER=True
ROI_MIN_RATIO=0.02
ROI_MAX_RATIO=0.98
MIN_BOX_SIZE_PX=2
MAX_BOX_SIZE_PX=100
NMS_IOU_THRESHOLD_2D=0.2
POST_FILTER_SCORE_THRESHOLD=0.01
TOP_K_2D_DETECTIONS=15
ENABLE_DOMAIN_GUARD=True
DOMAIN_GUARD_MIN_MEAN=0.1
DOMAIN_GUARD_MAX_MEAN=0.9
DOMAIN_GUARD_REJECT_MULTICHANNEL_2D=True
DOMAIN_GUARD_MAX_CHANNEL_DELTA=8.0
DEBUG_PRINT_RAW_OUTPUTS=True
DEBUG_MID_CONF_ONLY=False
PRINT_DEBUG_COUNTS=True
FALLBACK_TO_RAW_IF_EMPTY=False
MAX_RAW_FALLBACK_DETECTIONS=10
PROCESS_EVERY_NTH_SLICE=1
